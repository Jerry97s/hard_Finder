<Window x:Class="HdLabs.Memo.AiAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 비서"
        Width="520"
        Height="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <CheckBox x:Name="IncludeMemoCheck"
                      Content="메모 내용 포함"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Margin="0,0,12,0"/>
            <Button Content="현재 메모 요약"
                    Padding="10,6"
                    Click="Summarize_Click"
                    Margin="0,0,8,0"/>
            <TextBlock Text="서버:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <TextBox x:Name="ServerUrlBox"
                     Width="220"
                     VerticalAlignment="Center"
                     Text="http://127.0.0.1:8787/"
                     Padding="8,4"/>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="#559BB5AA"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ChatItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Padding="10"
                                    Margin="0,0,0,10"
                                    Background="{Binding BubbleBackground}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Role}"
                                               FontWeight="SemiBold"
                                               Opacity="0.75"/>
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     MinHeight="44"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10,8"
                     KeyDown="InputBox_KeyDown"/>
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="전송"
                    Padding="14,10"
                    Margin="10,0,0,0"
                    Click="Send_Click"/>
        </Grid>
    </Grid>
</Window>

